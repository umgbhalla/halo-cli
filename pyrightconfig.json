{
  "include": [
    "engine",
    "tests/unit",
    "tests/integration",
    "tests/e2e"
  ],
  "exclude": [
    "**/__pycache__",
    ".venv"
  ],
  "pythonVersion": "3.10",
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "basic",
  "reportMissingTypeStubs": false,
  "executionEnvironments": [
    {
      "root": "tests",
      "reportMissingImports": false,
      "reportAttributeAccessIssue": false,
      "reportArgumentType": false
    }
  ]
}
