{
  "name": "@context-labs/halo-app",
  "version": "0.1.2",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:static": "export HALO_DB_PATH=\"$PWD/data/halo-canvas.sqlite\"; bun run db:push && electrobun dev --watch",
    "dev:web": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
    "build:web": "vite build",
    "build:desktop": "bun run build:web && electrobun build --env=dev",
    "build:stable": "HALO_RELEASE_CHANNEL=stable electrobun build --env=stable",
    "build:canary": "HALO_RELEASE_CHANNEL=canary electrobun build --env=canary",
    "db:push": "drizzle-kit push",
    "fire:test-spans": "bun scripts/fire-test-spans.ts",
    "icons:generate": "bun scripts/generate-app-icons.ts",
    "release:manifest": "bun scripts/release-manifest.ts",
    "release:verify": "bun scripts/release-verify.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.10",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "1.170.7",
    "@tanstack/react-start": "1.168.10",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@uiw/react-json-view": "2.0.0-alpha.39",
    "bunqueue": "^2.7.14",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "^0.45.2",
    "electrobun": "^1.18.1",
    "hono": "^4.12.21",
    "lucide-react": "^1.16.0",
    "mermaid": "11.12.2",
    "react": "^19.2.6",
    "react-day-picker": "9.6.6",
    "react-dom": "^19.2.6",
    "react-syntax-highlighter": "15.6.1",
    "recharts": "2.13.0-alpha.5",
    "tailwind-merge": "2.6.0",
    "tw-animate-css": "1.2.9",
    "usehooks-ts": "2.16.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  }
