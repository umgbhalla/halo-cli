# Copy to .env and fill in. .env is gitignored — never commit real keys.

# ── Langfuse (keys are PER PROJECT) ─────────────────────────────────────────
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# For each project <NAME>, set LANGFUSE_<UPPER_SNAKE_NAME>_PUBLIC_KEY / _SECRET_KEY.
# Example for `--project myapp-staging`:
LANGFUSE_MYAPP_STAGING_PUBLIC_KEY=
LANGFUSE_MYAPP_STAGING_SECRET_KEY=

# ── LLM provider (OpenAI-compatible) ────────────────────────────────────────
# Anthropic: only /chat/completions exists (no Responses API), so flip the SDK:
HALO_OPENAI_API=chat_completions
OPENAI_BASE_URL=https://api.anthropic.com/v1/
# OPENAI_API_KEY falls back to ANTHROPIC_API_KEY if unset.
ANTHROPIC_API_KEY=
HALO_MODEL=claude-opus-4-8

# ── Run defaults (keep modest; depth*parallel drives concurrency/memory) ─────
HALO_MAX_DEPTH=1
HALO_MAX_PARALLEL=2
HALO_MAX_TURNS=8
